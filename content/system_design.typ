      table.cell(rowspan: 2, align: horizon)[2], 
      ```yasm csrrc r1, csr, r0 ```, table.cell(rowspan: 2)[Чтение CSR \ Запись CSR],
      ```yasm csrrw r0, csr, r1 ```,
      [3], ```yasm csrrw r1, dscratch0, r1  ```, [Восстановление значения r1 и\ чтение результата команды]
    
    )

  let mem_table =  table(
      columns: 3,
  
